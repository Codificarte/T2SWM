<?xml version="1.0" encoding="utf-8" ?>
<pages:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              xmlns:pages="clr-namespace:Mopups.Pages;assembly=Mopups"              
                 xmlns:CustomTemplates="clr-namespace:T2SLogistics.CustomTemplates"

             xmlns:resx="clr-namespace:T2SLogistics" NavigationPage.HasNavigationBar="False"
             x:Class="T2SLogistics.View.Popups.InsertProductQtyPopup">
    <Grid>
        <Grid BackgroundColor="{StaticResource Gray500}" Opacity="0.7" VerticalOptions="FillAndExpand">
            <!--<Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnClose"/>
            </Grid.GestureRecognizers>-->
        </Grid>

        <Border HeightRequest="400" Stroke="Transparent" Padding="20" Margin="20,0"
           BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 10,10,10,10">
            <Grid>
                <StackLayout Padding="20" Spacing="20">
                    <Label Text="{resx:Translate InsertProductQuantityPopup_InsertQuantity}" 
                           HorizontalOptions="CenterAndExpand" Style="{StaticResource BlackBoldTitleStyle}"/>
                    <StackLayout Spacing="10">
                        <Label Text="{resx:Translate InsertProductQuantityPopup_QtyProduced}" Style="{StaticResource Headline}" FontSize="15" HorizontalOptions="StartAndExpand"/>
                        <Border Padding="10,7" StrokeShape="RoundRectangle 10" Stroke="#EAEAEA" BackgroundColor="{StaticResource BackgroundWhite}">
                            <Entry x:Name="InsertQtyEntry" Text="{Binding InsertQty}" Completed="InsertQtyEntry_Completed"
             HorizontalOptions="CenterAndExpand" Keyboard="Numeric" FontSize="18"  />
                        </Border>
                    </StackLayout>
                    <StackLayout Spacing="10">
                        <Label Text="{resx:Translate InsertProductQuantityPopup_QtyBreaks}" Style="{StaticResource Headline}" FontSize="15" HorizontalOptions="StartAndExpand"/>
                        <Border Padding="10,7" StrokeShape="RoundRectangle 10" Stroke="#EAEAEA" BackgroundColor="{StaticResource BackgroundWhite}">
                            <Entry x:Name="QtyBreakEntry" Text="{Binding QtyBreak}" Completed="InsertQtyEntry_Completed"
                                   HorizontalOptions="CenterAndExpand" Keyboard="Numeric" FontSize="18"  />
                        </Border>
                    </StackLayout>
                    <Button Text="{resx:Translate InsertProductQuantityPopup_SaveProductionEntry}" Clicked="InsertQtyEntry_Completed" VerticalOptions="EndAndExpand" Style="{StaticResource LightBlackThemeButtonStyle}"/>
                </StackLayout>
                <CustomTemplates:CustomActivityIndicator x:Name="activityIndicator" Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center"/>

                <Button ImageSource="cancel.png" Clicked="OnClose" HeightRequest="10"
                       HorizontalOptions="End" VerticalOptions="Start" 
                       BackgroundColor="Transparent" 
                      
                       Margin="0"/>
            </Grid>
           
        </Border>
    </Grid>
</pages:PopupPage>
