<?xml version="1.0" encoding="utf-8" ?>
<mopup:PopupPage  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"       
                     xmlns:mopup="clr-namespace:Mopups.Pages;assembly=Mopups" 
                  xmlns:mopupsanim="clr-namespace:Mopups.Animations;assembly=Mopups"
             x:Class="T2SLogistics.View.Popups.IncompleteQuantityInputPopup" NavigationPage.HasNavigationBar="False" CloseWhenBackgroundIsClicked="True">
    <mopup:PopupPage.Animation>
        <mopupsanim:ScaleAnimation
            DurationIn="350"
            EasingIn="CubicOut"
            PositionIn="Bottom"     
            PositionOut="Bottom"
            ScaleIn="1"
            ScaleOut="0.9" />
    </mopup:PopupPage.Animation>
    <Grid>
        <Grid BackgroundColor="{StaticResource Gray500}" Opacity="0.7" VerticalOptions="FillAndExpand">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnClose"/>
            </Grid.GestureRecognizers>
        </Grid>
        <Border BackgroundColor="White" VerticalOptions="EndAndExpand" Stroke="Transparent" StrokeShape="RoundRectangle 20,20,0,0">
            <Grid RowDefinitions="auto,130,*,auto"  Margin="20,0" RowSpacing="20">
                <StackLayout Padding="20">
                    <Label Text="{Binding ProductBoxModel.ProductName}" Style="{StaticResource BlackBoldTitleStyle}" FontSize="Medium" HorizontalOptions="Center" />
                    <Label  FontSize="Medium" HorizontalOptions="Center" >
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Required: " Style="{StaticResource GrayRegularHeadingStyle}" />

                                <Span Text="{Binding ProductBoxModel.Quantity}" Style="{StaticResource GrayRegularHeadingStyle}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </StackLayout>
                <Border BackgroundColor="#F9FAFB" Grid.Row="1" StrokeShape="RoundRectangle 10" Padding="10" StrokeThickness="2">
                    <StackLayout HorizontalOptions="CenterAndExpand" Spacing="10">
                        <Label Text="{Binding InputQuantity}" HorizontalTextAlignment="Center" TextColor="{StaticResource DarkRedBorderColor}" FontSize="40" Style="{StaticResource BlackBoldTitleStyle}"/>
                        <Label Text="Quantity Recieved" TextTransform="Uppercase" HorizontalTextAlignment="Center" Style="{StaticResource GrayRegularHeadingStyle}"/>
                    </StackLayout>
                </Border>
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" RowSpacing="10" RowDefinitions="auto,auto,auto,auto,auto" Grid.Row="2">
                    <Button Text="1" FontSize="20" Padding="10" Command="{Binding Input_1_Command}" FontAttributes="Bold" BackgroundColor="{StaticResource DarkBlue}"/>
                    <Button Grid.Column="1" Text="2"  FontSize="20" Command="{Binding Input_2_Command}" Padding="10"  FontAttributes="Bold" BackgroundColor="{StaticResource DarkBlue}"/>
                    <Button Grid.Column="2" Text="3" FontSize="20" Command="{Binding Input_3_Command}" Padding="10"  FontAttributes="Bold" BackgroundColor="{StaticResource DarkBlue}"/>
                    <Button Grid.Row="1" Text="4" FontSize="20" Command="{Binding Input_4_Command}" Padding="10" FontAttributes="Bold" BackgroundColor="{StaticResource DarkBlue}"/>
                    <Button Grid.Column="1"  Grid.Row="1" Text="5" Command="{Binding Input_5_Command}"  FontSize="20" Padding="10"  FontAttributes="Bold" BackgroundColor="{StaticResource DarkBlue}"/>
                    <Button Grid.Column="2"  Grid.Row="1" Text="6" Command="{Binding Input_6_Command}" FontSize="20" Padding="10"  FontAttributes="Bold" BackgroundColor="{StaticResource DarkBlue}"/>
                    <Button Grid.Row="2" Text="7" FontSize="20" Command="{Binding Input_7_Command}" Padding="10" FontAttributes="Bold" BackgroundColor="{StaticResource DarkBlue}"/>
                    <Button Grid.Column="1"  Grid.Row="2" Text="8" Command="{Binding Input_8_Command}"  FontSize="20" Padding="10"  FontAttributes="Bold" BackgroundColor="{StaticResource DarkBlue}"/>
                    <Button Grid.Column="2"  Grid.Row="2" Text="9" Command="{Binding Input_9_Command}" FontSize="20" Padding="10"  FontAttributes="Bold" BackgroundColor="{StaticResource DarkBlue}"/>
                    <Button Grid.ColumnSpan="2" TextTransform="Uppercase" Grid.Row="3" Text="To Clean" Command="{Binding CleanInputCommand}" FontSize="20" Padding="10"  FontAttributes="Bold" BackgroundColor="{StaticResource DarkRedBorderColor}"/>
                    <Button Grid.ColumnSpan="2" TextTransform="Uppercase" Grid.Row="4" Text="0" FontSize="20" Command="{Binding Input_0_Command}" Padding="10"  FontAttributes="Bold" BackgroundColor="{StaticResource DarkBlue}"/>

                </Grid>
                <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="10" Padding="10,0,10,20">
                    <Button Text="Cancel" Clicked="OnClose" TextTransform="Uppercase" Padding="15" FontAttributes="Bold" TextColor="{StaticResource Black}" BackgroundColor="{StaticResource Gray100}"/>
                    <Button Grid.Column="1" Text="Confirm" Clicked="ConfirmButton_Clicked" Padding="15" TextTransform="Uppercase" TextColor="{StaticResource White}" FontAttributes="Bold" BackgroundColor="#10B981"/>

                </Grid>
            </Grid>
          
        </Border>
    </Grid>
</mopup:PopupPage>
