<?xml version="1.0" encoding="utf-8" ?>
<pages:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"  
             xmlns:pages="clr-namespace:Mopups.Pages;assembly=Mopups"           
                 xmlns:resx="clr-namespace:T2SLogistics" NavigationPage.HasNavigationBar="False"
             x:Class="T2SLogistics.View.Popups.ObservationDescriptionPopup"
             Title="ObservationDescriptionPopup">
    <Grid>
        <Grid BackgroundColor="{StaticResource Gray500}" Opacity="0.7" VerticalOptions="FillAndExpand">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnClose"/>
            </Grid.GestureRecognizers>
        </Grid>
        <Border HeightRequest="400" Stroke="Transparent" Padding="20" Margin="20,0"
           BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 10,10,10,10">
            <Grid>
                <StackLayout Padding="20" Spacing="20">
                    <Label Text="Add Observation notes" 
            HorizontalOptions="CenterAndExpand" Style="{StaticResource BlackBoldTitleStyle}"/>
                    <Border Padding="10,7" StrokeShape="RoundRectangle 10" Stroke="#EAEAEA" 
                            BackgroundColor="{StaticResource BackgroundWhite}">
                        <!--<Entry x:Name="obsNotesTextField" HorizontalOptions="CenterAndExpand"  FontSize="18"  />-->
                        <Editor x:Name="obsNotesTextField" FontSize="18" HeightRequest="150" />
                    </Border>
                    <Button Text="Save" Clicked="SaveNotes_Clicked" VerticalOptions="EndAndExpand" Style="{StaticResource LightBlackThemeButtonStyle}"/>
                </StackLayout>
            </Grid>
        </Border>
    </Grid>
</pages:PopupPage>